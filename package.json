{
  "name": "@hookvibe/hookcode-worker",
  "version": "0.1.2",
  "description": "Standalone HookCode worker runtime",
  "license": "MIT",
  "main": "dist/main.js",
  "bin": {
    "hookcode-worker": "dist/main.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "jest -c jest.config.cjs --runInBand",
    "prepack": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hookvibe/hookcode-worker.git"
  },
  "homepage": "https://github.com/hookvibe/hookcode-worker#readme",
  "bugs": {
    "url": "https://github.com/hookvibe/hookcode-worker/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@9.6.0",
  "dependencies": {
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.30",
    "@types/ws": "^8.18.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
